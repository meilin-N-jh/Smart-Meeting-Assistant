# Smart Meeting Assistant Configuration

# LLM runtime profile
# 7b-fp16: fastest option tested for the current meeting assistant workflow
# 14b-awq: stronger model, but slower on this machine
# 7b-awq: lighter fallback when fp16 is not practical
LLM_PROFILE=7b-fp16

# vLLM Configuration
# These can be omitted when using LLM_PROFILE defaults.
VLLM_BASE_URL=http://127.0.0.1:8400/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=qwen2.5-7b-fp16

# Local Model Path
LOCAL_QWEN_MODEL_PATH=/home/jiahuning2/LLM_Ability_Test/models/Qwen2.5-7B/Qwen2.5-7B-Instruct

# vLLM Startup Script
VLLM_START_SCRIPT=/home/jiahuning2/LLM_Ability_Test/models/Qwen2.5-7B/start_vllm_fp16.sh
VLLM_CONDA_ENV=qwen2.5

# Server Configuration
HOST=0.0.0.0
PORT=6493
DEBUG=false

# ASR Configuration
ASR_MODEL=medium
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16

# Speaker Diarization
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_HF_TOKEN=

# Audio Configuration
AUDIO_CHUNK_DURATION=5
AUDIO_SAMPLE_RATE=16000

# Meeting Processing
CHUNK_SIZE_WORDS=2000
CHUNK_OVERLAP_WORDS=200

# Logging
LOG_LEVEL=INFO
LOG_FILE=meeting_assistant.log
